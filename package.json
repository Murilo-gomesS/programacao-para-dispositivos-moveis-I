{
  "name": "app-scholar",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:lan": "npm run start:lan:autoip",
    "start:lan:clean": "npm run start:lan:autoip:clean",
    "start:lan:8081": "npm run start:lan:autoip",
    "start:lan:8081:clean": "npm run start:lan:autoip:clean",
    "start:lan:8082": "npm run start:lan:8082:autoip",
