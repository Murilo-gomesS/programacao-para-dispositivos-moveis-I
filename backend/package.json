{
  "name": "app-scholar-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "test": "jest",
    "db:up": "docker compose -f database/docker-compose.yml up -d",
    "db:down": "docker compose -f database/docker-compose.yml down",
    "db:reset": "powershell -NoProfile -Command \"docker compose -f database/docker-compose.yml down -v; docker compose -f database/docker-compose.yml up -d\"",
    "db:init": "node database/initDb.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.1.1"
  }
}
